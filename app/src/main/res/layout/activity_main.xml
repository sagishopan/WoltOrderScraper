<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wolt Order Scraper"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Captures Wolt orders to Google Sheets"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking..."
            android:textSize="14sp"
            android:textColor="#333333"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_enable_accessibility"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enable Accessibility Service"
            android:backgroundTint="#009DE0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Web App URL (from Google Apps Script)"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_web_app_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://script.google.com/macros/s/..."
            android:inputType="textUri"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save URL"
            android:backgroundTint="#009DE0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_test_connection"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Test Connection"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>

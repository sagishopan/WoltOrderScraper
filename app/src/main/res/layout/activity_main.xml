<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView android:id="@+id/tv_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Checking..." android:textSize="14sp" android:layout_marginBottom="16dp" />
        <ImageView android:id="@+id/iv_status_icon" android:layout_width="32dp" android:layout_height="32dp" android:visibility="gone" />
        <Button android:id="@+id/btn_enable_accessibility" android:layout_width="match_parent" android:layout_height="56dp" android:text="Enable Accessibility Service" android:layout_marginBottom="12dp" />
        <EditText android:id="@+id/et_spreadsheet_id" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Spreadsheet ID" android:padding="12dp" android:layout_marginBottom="12dp" />
        <EditText android:id="@+id/et_service_account_email" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Service Account Email" android:padding="12dp" android:layout_marginBottom="12dp" />
        <EditText android:id="@+id/et_private_key" android:layout_width="match_parent" android:layout_height="120dp" android:hint="Private Key" android:gravity="top" android:padding="12dp" android:layout_marginBottom="12dp" />
        <Button android:id="@+id/btn_save" android:layout_width="match_parent" android:layout_height="56dp" android:text="Save Settings" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/btn_test_connection" android:layout_width="match_parent" android:layout_height="56dp" android:text="Test Connection" />
    </LinearLayout>
</ScrollView>